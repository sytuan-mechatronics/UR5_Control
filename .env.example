TOOL_DOWN_RY=1.979381
TOOL_DOWN_RZ=0.237215


# ==================== HAND-EYE CALIBRATION ====================
# Format: 16 comma-separated values (4x4 matrix in row-major order)
# Default is identity matrix. Replace with your calibration result.
