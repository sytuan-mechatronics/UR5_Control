# ==================== ROBOT CONNECTIVITY ====================

ROBOT_IP=192.168.125.11
DASHBOARD_PORT=29999
URSCRIPT_PORT=30002
RTDE_PORT=30004


# ==================== FLASK PC2 SERVER ====================

PC2_HOST=0.0.0.0
