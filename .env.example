PAYLOAD_MASS_KG=1.0
TCP_OFFSET_X_M=-0.00904
TCP_OFFSET_Y_M=0.00905
TCP_OFFSET_Z_M=0.3251
TCP_OFFSET_RX_RAD=0.0185
TCP_OFFSET_RY_RAD=-0.0294
