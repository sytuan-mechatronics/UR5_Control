CAMERA_WIDTH=1280
CAMERA_HEIGHT=720
DEPTH_HOLE_FILL=True


# ==================== JOINT POSITIONS (FROM TEACH PENDANT) ====================
# Format: comma-separated values
# Example: 0.0,-1.5708,0.0,-1.5708,0.0,0.0

