# ==================== GEOMETRY ====================

PICK_APPROACH_OFFSET_Z=0.15
PICK_FINAL_OFFSET_Z=0.005
PICK_RETREAT_OFFSET_Z=0.15


# ==================== GRIPPER ONROBOT RG ====================

GRIPPER_OPEN_WIDTH=110
GRIPPER_CLOSE_FORCE=40
GRIPPER_CLOSE_WIDTH=0
GRIPPER_TIMEOUT_S=3.0


# ==================== RETRY ====================

MAX_PICK_RETRIES=3


# ==================== YOLO ====================

# Luu y: models/phoi.pt khong duoc commit len repo theo mac dinh .gitignore.
# Ban can copy model thu cong vao dung duong dan nay (hoac doi sang duong dan khac).
YOLO_MODEL_PATH=models/phoi.pt
YOLO_CONFIDENCE=0.5
YOLO_TARGET_CLASS=phoi


# ==================== CAMERA ====================

CAMERA_TRANSPORT=auto
CAMERA_IP=
