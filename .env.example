# ==================== ROBOT CONNECTIVITY ====================

ROBOT_IP=192.168.125.11
DASHBOARD_PORT=29999
URSCRIPT_PORT=30002
RTDE_PORT=30004


# ==================== FLASK PC2 SERVER ====================

PC2_HOST=0.0.0.0
PC2_PORT=5001


# ==================== PC1 CALLBACK ====================

PC1_BASE_URL=http://192.168.1.100:5000
PC1_CALLBACK_ENABLED=False
PC1_WEBHOOK_SECRET=


# ==================== MOTION PARAMETERS ====================

JOINT_ACCEL=1.0
JOINT_VEL=0.8
LINEAR_ACCEL=0.3
LINEAR_VEL=0.1
